{
  "name": "edu-savvy-ai",
  "version": "1.0.0",
  "private": true,
  "description": "AI-powered education platform for African schools",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm run dev --workspace=@edu-savvy/api",
    "dev:web": "npm run dev --workspace=@edu-savvy/web",
    "build": "npm run build --workspaces --if-present",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "npm run seed --workspace=@edu-savvy/api",
    "db:studio": "prisma studio",
    "setup": "node scripts/setup.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "prisma": "^6.3.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
